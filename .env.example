# Copy to .env.local and fill in. Never commit .env.local.

# --- Database (Neon) — use the POOLED connection string (host contains "-pooler") ---
DATABASE_URL=

# --- Auth (Clerk) ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# --- OCR (Google Gemini, read by the Vercel AI SDK) — used from Phase 2 ---
GOOGLE_GENERATIVE_AI_API_KEY=
# Optional model pin. Defaults to the rolling alias gemini-flash-lite-latest
# (pinned Gemini models keep getting retired).
# GEMINI_MODEL=

# --- Email (Resend) — used from Phase 3 ---
RESEND_API_KEY=
# Sender address. Leave unset until a domain is verified with Resend — the
# default test sender (onboarding@resend.dev) delivers ONLY to the Resend
# account owner's email. After verification: "Expiry Tracker <reminders@yourdomain.tld>"
# EMAIL_FROM=

# --- Image storage (Vercel Blob) — used from Phase 5 ---
BLOB_READ_WRITE_TOKEN=

# --- Cron (Phase 3): random string; Vercel sends it back as "Authorization: Bearer <value>" ---
CRON_SECRET=

# --- App ---
APP_TZ=Asia/Kolkata
NEXT_PUBLIC_APP_URL=http://localhost:3000
